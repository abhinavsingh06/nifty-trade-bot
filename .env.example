BOT_MODE=paper
PAPER_INITIAL_CAPITAL=20000
PAPER_DEFAULT_LOTS=1
MARKET_TIMEZONE=Asia/Kolkata
MARKET_OPEN_HOUR=9
MARKET_OPEN_MINUTE=15
MARKET_CLOSE_HOUR=15
MARKET_CLOSE_MINUTE=30
# 1 = block on NSE holiday dates in data/nse-holidays.json (signals, candles, auto-signals, risk “market session” check)
MARKET_SESSION_STRICT=0
# Optional path to custom holiday JSON (same shape as data/nse-holidays.json)
NSE_HOLIDAY_CALENDAR_PATH=
# After T1 (breakeven arm): ratchet stop under peak NIFTY / peak premium (0 = disable that leg)
TRAILING_STOP_UNDERLYING_POINTS=0
TRAILING_STOP_OPTION_POINTS=0
# Live exits: poll /orders for fill; EXIT_WAIT_FOR_FILL=1 does not close locally until filled
EXIT_WAIT_FOR_FILL=0
EXIT_POLL_MAX_MS=90000
EXIT_POLL_INTERVAL_MS=2000
# 0 = allow npm run monitor off-hours (e.g. overnight); 1 = skip monitor when session closed
MONITOR_REQUIRE_TRADE_SESSION=1
MAX_RISK_PER_TRADE=2500
MAX_DAILY_LOSS=7500
MAX_TRADES_PER_DAY=3
# Paper BUY entries allowed per IST calendar day (dashboard journal); 0 = unlimited
DAILY_TRADE_SLOT_LIMIT=3
# Max notional (₹) per paper BUY; 0 = no cap
PAPER_MAX_TRADE_RUPEES=0
# Max paper BUY notional as % of wallet cash; 0 = no cap
PAPER_MAX_TRADE_PCT_WALLET=0
# After this many losing paper closes today (IST), block further paper buys until next session
PAPER_COOLDOWN_LOSS_COUNT_TODAY=0
# When today's realized paper P&L ≤ this negative ₹ amount, block further paper buys (0 = off)
PAPER_COOLDOWN_MAX_DAILY_LOSS_RUPEES=0
# Kill-switch: block all new entries (paper + live autotrade). Runtime toggle also exists via POST /api/desk-no-new-entries
NO_NEW_ENTRIES=0
# Dashboard websocket refresh (ms): slower when flat, faster when positions open
DASHBOARD_BROADCAST_MS_IDLE=15000
DASHBOARD_BROADCAST_MS_OPEN=5000
# Mark option LTP stale in UI if last quote batch older than this (ms)
QUOTE_STALE_AFTER_MS=60000
SESSION_HEALTH_TTL_MS=60000
MIN_SIGNAL_SCORE=7
MIN_CONFIRMATION_COUNT=3
HISTORICAL_LOOKBACK_MINUTES=120
BACKTEST_LOOKAHEAD_CANDLES=6
BACKTEST_LOOKBACK_DAYS=5
NIFTY_INDEX_EXCHANGE=NSE
NIFTY_INDEX_TRADINGSYMBOL=NIFTY 50
NIFTY_INDEX_INSTRUMENT_TOKEN=256265
OPTION_EXCHANGE=NFO
OPTION_STRIKE_STEP=50
EXPIRY_PREFERENCE=current
ORDER_VARIETY=regular
ORDER_PRODUCT=MIS
ORDER_VALIDITY=DAY
ORDER_TYPE=MARKET
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=
ZERODHA_USER_ID=JIG311
ZERODHA_REDIRECT_URL=http://127.0.0.1:8000/
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
CRYPTO_PROVIDER=coingecko
CRYPTO_BASE_URL=https://api.coingecko.com/api/v3
CRYPTO_API_KEY=
CRYPTO_COIN_ID=bitcoin
CRYPTO_VS_CURRENCY=usd
CRYPTO_SYMBOL=BTCUSDT
CRYPTO_INTERVAL_MINUTES=15
CRYPTO_LOOKBACK_CANDLES=24
NIFTY_SYMBOL=NIFTY 50
OPTION_LOT_SIZE=65

# Unattended runs: with `npm run dashboard`, refresh signals at market open + every N minutes (IST market hours). Needs valid ZERODHA_ACCESS_TOKEN for live candles.
AUTO_SIGNALS_ENABLED=0
AUTO_SIGNALS_INTERVAL_MINUTES=15
# Optional: also run when index spot moves ≥ this % vs last saved run (0 = disabled; uses a quick quote poll between interval ticks).
AUTO_SIGNALS_SPOT_MOVE_PCT=0

# Signal patience: `patient` downgrades rushed TRADEABLE to WAIT when recent range is tight or the latest bar lacks follow-through vs the prior bar.
TRADE_DISCIPLINE=normal
SIGNAL_MIN_RECENT_RANGE_POINTS=0
SIGNAL_FOLLOW_THROUGH_BUFFER=3

# Webhook for TRADEABLE-only pushes (e.g. n8n → WhatsApp). Leave empty to disable.
NOTIFY_WEBHOOK_URL=
NOTIFY_WEBHOOK_SECRET=
